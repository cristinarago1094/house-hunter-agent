<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.crago.house-hunter-agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/crago/Library/CloudStorage/OneDrive-Microsoft/Documents/House Hunter Agent/scripts/run_daily.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/crago/Library/CloudStorage/OneDrive-Microsoft/Documents/House Hunter Agent</string>

